# Nifty Auto-Trader v14 — Environment Variables
# Set these in Vercel Dashboard → Settings → Environment Variables

# LLM Providers (Groq is required, others are optional fallbacks)
GROQ_API_KEY=gsk_...
CEREBRAS_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=380433720

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cron authentication
CRON_SECRET=generate_a_random_string_here

# Trading config
KITE_USER_ID=HG6130
ANALYSIS_SCORE_THRESHOLD=8
MAX_TRADES_PER_DAY=2
TRADE_CUTOFF_IST_MINUTES=825
